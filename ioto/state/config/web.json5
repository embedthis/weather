{
    documents: "@site",
    listen: [
        "http://:80"
    ],
    routes: [
        {
            match: "/ai/",
            handler: "action",
            methods: [
                "GET",
                "POST"
            ]
        },
        {
            match: "",
            handler: "file",
            methods: [
                "GET"
            ]
        }
    ],
    signatures: {
        enable: false
    },
    webSockets: {
        ping: "never",
        protocol: "chat",
        validateUTF: false
    }
}

